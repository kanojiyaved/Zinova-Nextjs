# ── Backend Configuration ─────────────────────────────────────────────────────

# OTP Email Configuration (Brevo SMTP)
# Get these from your Brevo account: https://app.brevo.com/
BREVO_SMTP_SERVER=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_EMAIL=your_smtp_login@smtp-brevo.com
BREVO_PASSWORD=your_smtp_key_here
BREVO_SENDER_EMAIL=verified_sender@example.com

# CORS Settings (Frontend URL)
CORS_ORIGIN=http://localhost:3000

# ── Frontend Configuration ────────────────────────────────────────────────────
VITE_API_URL=http://127.0.0.1:8000